using ECommerce.Application.DTOs.Cart;
using ECommerce.Application.DTOs.Common;
using ECommerce.Application.Services;
using Microsoft.AspNetCore.Authorization;
using Microsoft.AspNetCore.Mvc;

namespace ECommerce.API.Controllers;

/// <summary>
/// Controller for shopping cart management operations.
/// Supports both authenticated users and guest sessions.
/// </summary>
[ApiController]
[Route("api/[controller]")]
[Produces("application/json")]
public class CartController : ControllerBase
{
    private readonly ICartService _cartService;
    private readonly ILogger<CartController> _logger;

    public CartController(ICartService cartService, ILogger<CartController> logger)
    {
        _cartService = cartService;
        _logger = logger;
    }

    /// <summary>
    /// Retrieves the user's shopping cart.
    /// For authenticated users, retrieves their user cart.
    /// For guests, retrieves cart by session ID from query parameter.
    /// </summary>
    /// <param name="sessionId">The session ID for guest carts (optional, required for guests).</param>
    /// <returns>The shopping cart with items and totals.</returns>
    /// <response code="200">Cart retrieved successfully.</response>
    /// <response code="400">Session ID is required for guests.</response>
    /// <response code="500">Internal server error.</response>
    [HttpGet]
    [ProducesResponseType(typeof(ApiResponse<CartDto>), StatusCodes.Status200OK)]
    [ProducesResponseType(typeof(ApiResponse<CartDto>), StatusCodes.Status400BadRequest)]
    [ProducesResponseType(typeof(ApiResponse<CartDto>), StatusCodes.Status500InternalServerError)]
    public async Task<ActionResult<ApiResponse<CartDto>>> GetCart([FromQuery] string? sessionId)
    {
        try
        {
            Guid? userId = null;
            var userIdClaim = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (!string.IsNullOrEmpty(userIdClaim))
            {
                userId = Guid.Parse(userIdClaim);
            }

            // Require session ID for guests
            if (!userId.HasValue && string.IsNullOrWhiteSpace(sessionId))
            {
                return BadRequest(ApiResponse<CartDto>.Error("Session ID is required for guest carts"));
            }

            var cart = await _cartService.GetCartAsync(userId, sessionId);
            return Ok(ApiResponse<CartDto>.Ok(cart, "Cart retrieved successfully"));
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error retrieving cart");
            return StatusCode(500, ApiResponse<CartDto>.Error("An error occurred while retrieving the cart"));
        }
    }

    /// <summary>
    /// Adds a product to the shopping cart.
    /// </summary>
    /// <param name="addToCartDto">The product ID and quantity to add.</param>
    /// <param name="sessionId">The session ID for guest carts (optional, required for guests).</param>
    /// <returns>The updated shopping cart.</returns>
    /// <response code="200">Product added to cart successfully.</response>
    /// <response code="400">Invalid product data or insufficient stock.</response>
    /// <response code="500">Internal server error.</response>
    [HttpPost("items")]
    [ProducesResponseType(typeof(ApiResponse<CartDto>), StatusCodes.Status200OK)]
    [ProducesResponseType(typeof(ApiResponse<CartDto>), StatusCodes.Status400BadRequest)]
    [ProducesResponseType(typeof(ApiResponse<CartDto>), StatusCodes.Status500InternalServerError)]
    public async Task<ActionResult<ApiResponse<CartDto>>> AddToCart([FromBody] AddToCartDto addToCartDto, [FromQuery] string? sessionId)
    {
        try
        {
            if (!ModelState.IsValid)
            {
                var errors = ModelState.Values.SelectMany(v => v.Errors).Select(e => e.ErrorMessage).ToList();
                return BadRequest(ApiResponse<CartDto>.Error("Validation failed", errors));
            }

            Guid? userId = null;
            var userIdClaim = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (!string.IsNullOrEmpty(userIdClaim))
            {
                userId = Guid.Parse(userIdClaim);
            }

            if (!userId.HasValue && string.IsNullOrWhiteSpace(sessionId))
            {
                return BadRequest(ApiResponse<CartDto>.Error("Session ID is required for guest carts"));
            }

            var cart = await _cartService.AddToCartAsync(addToCartDto, userId, sessionId);
            _logger.LogInformation("Product added to cart: {ProductId}, Quantity: {Quantity}", addToCartDto.ProductId, addToCartDto.Quantity);

            return Ok(ApiResponse<CartDto>.Ok(cart, "Product added to cart successfully"));
        }
        catch (ArgumentException ex)
        {
            return BadRequest(ApiResponse<CartDto>.Error(ex.Message));
        }
        catch (InvalidOperationException ex)
        {
            return BadRequest(ApiResponse<CartDto>.Error(ex.Message));
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error adding product to cart");
            return StatusCode(500, ApiResponse<CartDto>.Error("An error occurred while adding product to cart"));
        }
    }

    /// <summary>
    /// Updates the quantity of a product in the cart.
    /// </summary>
    /// <param name="cartItemId">The cart item ID to update.</param>
    /// <param name="updateCartItemDto">The new quantity for the item.</param>
    /// <param name="sessionId">The session ID for guest carts (optional, required for guests).</param>
    /// <returns>The updated shopping cart.</returns>
    /// <response code="200">Cart item updated successfully.</response>
    /// <response code="400">Invalid quantity or insufficient stock.</response>
    /// <response code="404">Cart item not found.</response>
    /// <response code="500">Internal server error.</response>
    [HttpPut("items/{cartItemId}")]
    [ProducesResponseType(typeof(ApiResponse<CartDto>), StatusCodes.Status200OK)]
    [ProducesResponseType(typeof(ApiResponse<CartDto>), StatusCodes.Status400BadRequest)]
    [ProducesResponseType(typeof(ApiResponse<CartDto>), StatusCodes.Status404NotFound)]
    [ProducesResponseType(typeof(ApiResponse<CartDto>), StatusCodes.Status500InternalServerError)]
    public async Task<ActionResult<ApiResponse<CartDto>>> UpdateCartItem([FromRoute] Guid cartItemId, [FromBody] UpdateCartItemDto updateCartItemDto, [FromQuery] string? sessionId)
    {
        try
        {
            if (!ModelState.IsValid)
            {
                var errors = ModelState.Values.SelectMany(v => v.Errors).Select(e => e.ErrorMessage).ToList();
                return BadRequest(ApiResponse<CartDto>.Error("Validation failed", errors));
            }

            Guid? userId = null;
            var userIdClaim = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (!string.IsNullOrEmpty(userIdClaim))
            {
                userId = Guid.Parse(userIdClaim);
            }

            var cart = await _cartService.UpdateCartItemAsync(cartItemId, updateCartItemDto, userId, sessionId);
            _logger.LogInformation("Cart item updated: {CartItemId}, NewQuantity: {Quantity}", cartItemId, updateCartItemDto.Quantity);

            return Ok(ApiResponse<CartDto>.Ok(cart, "Cart item updated successfully"));
        }
        catch (ArgumentException ex)
        {
            return BadRequest(ApiResponse<CartDto>.Error(ex.Message));
        }
        catch (InvalidOperationException ex)
        {
            return BadRequest(ApiResponse<CartDto>.Error(ex.Message));
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error updating cart item: {CartItemId}", cartItemId);
            return StatusCode(500, ApiResponse<CartDto>.Error("An error occurred while updating cart item"));
        }
    }

    /// <summary>
    /// Removes a product from the shopping cart.
    /// </summary>
    /// <param name="cartItemId">The cart item ID to remove.</param>
    /// <param name="sessionId">The session ID for guest carts (optional, required for guests).</param>
    /// <returns>The updated shopping cart.</returns>
    /// <response code="200">Product removed from cart successfully.</response>
    /// <response code="404">Cart item not found.</response>
    /// <response code="500">Internal server error.</response>
    [HttpDelete("items/{cartItemId}")]
    [ProducesResponseType(typeof(ApiResponse<CartDto>), StatusCodes.Status200OK)]
    [ProducesResponseType(typeof(ApiResponse<CartDto>), StatusCodes.Status404NotFound)]
    [ProducesResponseType(typeof(ApiResponse<CartDto>), StatusCodes.Status500InternalServerError)]
    public async Task<ActionResult<ApiResponse<CartDto>>> RemoveFromCart([FromRoute] Guid cartItemId, [FromQuery] string? sessionId)
    {
        try
        {
            Guid? userId = null;
            var userIdClaim = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (!string.IsNullOrEmpty(userIdClaim))
            {
                userId = Guid.Parse(userIdClaim);
            }

            var cart = await _cartService.RemoveFromCartAsync(cartItemId, userId, sessionId);
            _logger.LogInformation("Item removed from cart: {CartItemId}", cartItemId);

            return Ok(ApiResponse<CartDto>.Ok(cart, "Product removed from cart successfully"));
        }
        catch (InvalidOperationException ex)
        {
            return BadRequest(ApiResponse<CartDto>.Error(ex.Message));
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error removing item from cart: {CartItemId}", cartItemId);
            return StatusCode(500, ApiResponse<CartDto>.Error("An error occurred while removing item from cart"));
        }
    }

    /// <summary>
    /// Clears all items from the shopping cart.
    /// </summary>
    /// <param name="sessionId">The session ID for guest carts (optional, required for guests).</param>
    /// <returns>An empty shopping cart.</returns>
    /// <response code="200">Cart cleared successfully.</response>
    /// <response code="500">Internal server error.</response>
    [HttpDelete]
    [ProducesResponseType(typeof(ApiResponse<CartDto>), StatusCodes.Status200OK)]
    [ProducesResponseType(typeof(ApiResponse<CartDto>), StatusCodes.Status500InternalServerError)]
    public async Task<ActionResult<ApiResponse<CartDto>>> ClearCart([FromQuery] string? sessionId)
    {
        try
        {
            Guid? userId = null;
            var userIdClaim = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (!string.IsNullOrEmpty(userIdClaim))
            {
                userId = Guid.Parse(userIdClaim);
            }

            var cart = await _cartService.ClearCartAsync(userId, sessionId);
            _logger.LogInformation("Cart cleared for user: {UserId}, session: {SessionId}", userId, sessionId);

            return Ok(ApiResponse<CartDto>.Ok(cart, "Cart cleared successfully"));
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error clearing cart");
            return StatusCode(500, ApiResponse<CartDto>.Error("An error occurred while clearing cart"));
        }
    }

    /// <summary>
    /// Gets the number of items in the cart.
    /// </summary>
    /// <param name="sessionId">The session ID for guest carts (optional, required for guests).</param>
    /// <returns>The number of items in the cart.</returns>
    /// <response code="200">Item count retrieved successfully.</response>
    /// <response code="400">Session ID is required for guests.</response>
    /// <response code="500">Internal server error.</response>
    [HttpGet("count")]
    [ProducesResponseType(typeof(ApiResponse<CartCountDto>), StatusCodes.Status200OK)]
    [ProducesResponseType(typeof(ApiResponse<CartCountDto>), StatusCodes.Status400BadRequest)]
    [ProducesResponseType(typeof(ApiResponse<CartCountDto>), StatusCodes.Status500InternalServerError)]
    public async Task<ActionResult<ApiResponse<CartCountDto>>> GetCartItemCount([FromQuery] string? sessionId)
    {
        try
        {
            Guid? userId = null;
            var userIdClaim = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (!string.IsNullOrEmpty(userIdClaim))
            {
                userId = Guid.Parse(userIdClaim);
            }

            if (!userId.HasValue && string.IsNullOrWhiteSpace(sessionId))
            {
                return BadRequest(ApiResponse<CartCountDto>.Error("Session ID is required for guest carts"));
            }

            var count = await _cartService.GetCartItemCountAsync(userId, sessionId);
            return Ok(ApiResponse<CartCountDto>.Ok(new CartCountDto { ItemCount = count }, "Cart item count retrieved successfully"));
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error getting cart item count");
            return StatusCode(500, ApiResponse<CartCountDto>.Error("An error occurred while getting cart item count"));
        }
    }

    /// <summary>
    /// Calculates the total price of the cart including tax and shipping.
    /// </summary>
    /// <param name="taxRate">The tax rate as a decimal (e.g., 0.1 for 10%). Default: 0.</param>
    /// <param name="shippingCost">The shipping cost. Default: 0.</param>
    /// <param name="sessionId">The session ID for guest carts (optional, required for guests).</param>
    /// <returns>The calculated total amount.</returns>
    /// <response code="200">Cart total calculated successfully.</response>
    /// <response code="400">Session ID is required for guests.</response>
    /// <response code="500">Internal server error.</response>
    [HttpPost("calculate-total")]
    [ProducesResponseType(typeof(ApiResponse<CartTotalDto>), StatusCodes.Status200OK)]
    [ProducesResponseType(typeof(ApiResponse<CartTotalDto>), StatusCodes.Status400BadRequest)]
    [ProducesResponseType(typeof(ApiResponse<CartTotalDto>), StatusCodes.Status500InternalServerError)]
    public async Task<ActionResult<ApiResponse<CartTotalDto>>> CalculateCartTotal([FromQuery] decimal taxRate = 0, [FromQuery] decimal shippingCost = 0, [FromQuery] string? sessionId = null)
    {
        try
        {
            Guid? userId = null;
            var userIdClaim = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (!string.IsNullOrEmpty(userIdClaim))
            {
                userId = Guid.Parse(userIdClaim);
            }

            if (!userId.HasValue && string.IsNullOrWhiteSpace(sessionId))
            {
                return BadRequest(ApiResponse<CartTotalDto>.Error("Session ID is required for guest carts"));
            }

            var total = await _cartService.CalculateCartTotalAsync(userId, sessionId, taxRate, shippingCost);
            return Ok(ApiResponse<CartTotalDto>.Ok(new CartTotalDto { Total = total }, "Cart total calculated successfully"));
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error calculating cart total");
            return StatusCode(500, ApiResponse<CartTotalDto>.Error("An error occurred while calculating cart total"));
        }
    }

    /// <summary>
    /// Applies a promo code to the cart for discount.
    /// </summary>
    /// <param name="request">The promo code to apply.</param>
    /// <param name="sessionId">The session ID for guest carts (optional, required for guests).</param>
    /// <returns>The discount amount applied.</returns>
    /// <response code="200">Promo code applied successfully.</response>
    /// <response code="400">Invalid promo code or session ID is required for guests.</response>
    /// <response code="500">Internal server error.</response>
    [HttpPost("apply-promo")]
    [ProducesResponseType(typeof(ApiResponse<ApplyPromoResponseDto>), StatusCodes.Status200OK)]
    [ProducesResponseType(typeof(ApiResponse<ApplyPromoResponseDto>), StatusCodes.Status400BadRequest)]
    [ProducesResponseType(typeof(ApiResponse<ApplyPromoResponseDto>), StatusCodes.Status500InternalServerError)]
    public async Task<ActionResult<ApiResponse<ApplyPromoResponseDto>>> ApplyPromoCode([FromBody] ApplyPromoRequestDto request, [FromQuery] string? sessionId)
    {
        try
        {
            if (string.IsNullOrWhiteSpace(request.PromoCode))
            {
                return BadRequest(ApiResponse<ApplyPromoResponseDto>.Error("Promo code is required"));
            }

            Guid? userId = null;
            var userIdClaim = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (!string.IsNullOrEmpty(userIdClaim))
            {
                userId = Guid.Parse(userIdClaim);
            }

            if (!userId.HasValue && string.IsNullOrWhiteSpace(sessionId))
            {
                return BadRequest(ApiResponse<ApplyPromoResponseDto>.Error("Session ID is required for guest carts"));
            }

            var discountAmount = await _cartService.ApplyPromoCodeAsync(request.PromoCode, userId, sessionId);
            if (discountAmount == 0)
            {
                return BadRequest(ApiResponse<ApplyPromoResponseDto>.Error("Invalid or expired promo code"));
            }

            _logger.LogInformation("Promo code applied: {PromoCode}, Discount: {DiscountAmount}", request.PromoCode, discountAmount);
            return Ok(ApiResponse<ApplyPromoResponseDto>.Ok(
                new ApplyPromoResponseDto { DiscountAmount = discountAmount },
                "Promo code applied successfully"));
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error applying promo code");
            return StatusCode(500, ApiResponse<ApplyPromoResponseDto>.Error("An error occurred while applying promo code"));
        }
    }

    /// <summary>
    /// Removes the applied promo code from the cart.
    /// </summary>
    /// <param name="sessionId">The session ID for guest carts (optional, required for guests).</param>
    /// <returns>The updated cart without the discount.</returns>
    /// <response code="200">Promo code removed successfully.</response>
    /// <response code="400">Session ID is required for guests.</response>
    /// <response code="500">Internal server error.</response>
    [HttpPost("remove-promo")]
    [ProducesResponseType(typeof(ApiResponse<CartDto>), StatusCodes.Status200OK)]
    [ProducesResponseType(typeof(ApiResponse<CartDto>), StatusCodes.Status400BadRequest)]
    [ProducesResponseType(typeof(ApiResponse<CartDto>), StatusCodes.Status500InternalServerError)]
    public async Task<ActionResult<ApiResponse<CartDto>>> RemovePromoCode([FromQuery] string? sessionId)
    {
        try
        {
            Guid? userId = null;
            var userIdClaim = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (!string.IsNullOrEmpty(userIdClaim))
            {
                userId = Guid.Parse(userIdClaim);
            }

            if (!userId.HasValue && string.IsNullOrWhiteSpace(sessionId))
            {
                return BadRequest(ApiResponse<CartDto>.Error("Session ID is required for guest carts"));
            }

            var cart = await _cartService.RemovePromoCodeAsync(userId, sessionId);
            _logger.LogInformation("Promo code removed from cart");

            return Ok(ApiResponse<CartDto>.Ok(cart, "Promo code removed successfully"));
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error removing promo code");
            return StatusCode(500, ApiResponse<CartDto>.Error("An error occurred while removing promo code"));
        }
    }

    /// <summary>
    /// Validates that all products in the cart are in stock.
    /// </summary>
    /// <param name="sessionId">The session ID for guest carts (optional, required for guests).</param>
    /// <returns>Validation result.</returns>
    /// <response code="200">Cart validation result returned.</response>
    /// <response code="400">Session ID is required for guests.</response>
    /// <response code="500">Internal server error.</response>
    [HttpGet("validate")]
    [ProducesResponseType(typeof(ApiResponse<CartValidationDto>), StatusCodes.Status200OK)]
    [ProducesResponseType(typeof(ApiResponse<CartValidationDto>), StatusCodes.Status400BadRequest)]
    [ProducesResponseType(typeof(ApiResponse<CartValidationDto>), StatusCodes.Status500InternalServerError)]
    public async Task<ActionResult<ApiResponse<CartValidationDto>>> ValidateCart([FromQuery] string? sessionId)
    {
        try
        {
            Guid? userId = null;
            var userIdClaim = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (!string.IsNullOrEmpty(userIdClaim))
            {
                userId = Guid.Parse(userIdClaim);
            }

            if (!userId.HasValue && string.IsNullOrWhiteSpace(sessionId))
            {
                return BadRequest(ApiResponse<CartValidationDto>.Error("Session ID is required for guest carts"));
            }

            var isValid = await _cartService.ValidateCartAsync(userId, sessionId);
            return Ok(ApiResponse<CartValidationDto>.Ok(
                new CartValidationDto { IsValid = isValid },
                isValid ? "Cart is valid" : "Some items in cart have insufficient stock"));
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error validating cart");
            return StatusCode(500, ApiResponse<CartValidationDto>.Error("An error occurred while validating cart"));
        }
    }

    /// <summary>
    /// Transfers a guest cart to a registered user after login.
    /// </summary>
    /// <param name="sessionId">The session ID of the guest cart to transfer.</param>
    /// <returns>The merged cart containing items from both guest and user carts.</returns>
    /// <response code="200">Cart transferred successfully.</response>
    /// <response code="400">Session ID is required or user is not authenticated.</response>
    /// <response code="500">Internal server error.</response>
    [HttpPost("transfer-guest/{sessionId}")]
    [Authorize]
    [ProducesResponseType(typeof(ApiResponse<CartDto>), StatusCodes.Status200OK)]
    [ProducesResponseType(typeof(ApiResponse<CartDto>), StatusCodes.Status400BadRequest)]
    [ProducesResponseType(typeof(ApiResponse<CartDto>), StatusCodes.Status500InternalServerError)]
    public async Task<ActionResult<ApiResponse<CartDto>>> TransferGuestCart([FromRoute] string sessionId)
    {
        try
        {
            var userId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (string.IsNullOrEmpty(userId))
            {
                return BadRequest(ApiResponse<CartDto>.Error("User is not authenticated"));
            }

            if (string.IsNullOrWhiteSpace(sessionId))
            {
                return BadRequest(ApiResponse<CartDto>.Error("Session ID is required"));
            }

            var cart = await _cartService.TransferGuestCartToUserAsync(sessionId, Guid.Parse(userId));
            _logger.LogInformation("Guest cart transferred to user: {UserId}, SessionId: {SessionId}", userId, sessionId);

            return Ok(ApiResponse<CartDto>.Ok(cart, "Guest cart transferred successfully"));
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error transferring guest cart");
            return StatusCode(500, ApiResponse<CartDto>.Error("An error occurred while transferring cart"));
        }
    }
}

#region DTOs

public class CartCountDto
{
    public int ItemCount { get; set; }
}

public class CartTotalDto
{
    public decimal Total { get; set; }
}

public class ApplyPromoRequestDto
{
    public string PromoCode { get; set; } = null!;
}

public class ApplyPromoResponseDto
{
    public decimal DiscountAmount { get; set; }
}

public class CartValidationDto
{
    public bool IsValid { get; set; }
}

#endregion
