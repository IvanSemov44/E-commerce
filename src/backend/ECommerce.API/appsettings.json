{
  "AppUrl": "http://localhost:5173",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "AllowedOrigins": [
    "https://yourdomain.com",
    "https://admin.yourdomain.com",
    "https://www.yourdomain.com"
  ],
  "Jwt": {
    "SecretKey": "",
    "Issuer": "ecommerce-api",
    "Audience": "ecommerce-client",
    "ExpireMinutes": 60
  },
  "PaymentWebhook": {
    "Secret": ""
  },
  "BusinessRules": {
    "FreeShippingThreshold": 100.00,
    "StandardShippingCost": 10.00,
    "TaxRate": 0.08
  },
  "Monitoring": {
    "EnableDetailedHealthChecks": true,
    "HealthCheckTimeoutMs": 5000,
    "MemoryThresholdMB": 1024,
    "EnableHealthCheckUI": false
  },
  "EmailProvider": "SendGrid",
  "SendGrid": {
    "ApiKey": "",
    "FromEmail": "noreply@ecommerce.com",
    "FromName": "E-Commerce Platform"
  },
  "Smtp": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "Username": "",
    "Password": "",
    "FromEmail": "",
    "FromName": "E-Commerce Platform",
    "EnableSsl": true
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      { 
        "Name": "File", 
        "Args": { 
          "path": "logs/app-.txt", 
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        } 
      },
      { 
        "Name": "File", 
        "Args": { 
          "path": "logs/security-.txt", 
          "rollingInterval": "Day",
          "restrictedToMinimumLevel": "Warning",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        } 
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithCorrelationId"],
    "Properties": {
      "Application": "ECommerce.API"
    }
  },
  "Seq": {
    "ServerUrl": ""
  },
  "ApplicationInsights": {
    "InstrumentationKey": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
