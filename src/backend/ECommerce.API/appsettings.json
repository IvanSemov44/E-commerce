{
  "AppUrl": "http://localhost:5173",
  "ConnectionStrings": {
    "DefaultConnection": "",
    "CatalogConnection": "",
    "ShoppingConnection": ""
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "InstanceName": "ecommerce:"
  },
  "IntegrationMessaging": {
    "Transport": "InMemory",
    "Outbox": {
      "MaxRetryAttempts": 5,
      "BaseRetryDelaySeconds": 5,
      "MaxRetryDelaySeconds": 300,
      "BatchSize": 100
    },
    "OrderFulfillmentSaga": {
      "InventoryTimeoutMinutes": 15,
      "TimeoutPollIntervalSeconds": 30
    },
    "RabbitMq": {
      "Host": "localhost",
      "VirtualHost": "/",
      "Username": "guest",
      "Password": "guest"
    }
  },
  "AllowedOrigins": [
    "https://ecommerce-storefront-p9c3.onrender.com",
    "https://ecommerce-admin-c0x9.onrender.com",
    "http://localhost:5173",
    "http://localhost:5174"
  ],
  "Jwt": {
    "SecretKey": "",
    "Issuer": "ecommerce-api",
    "Audience": "ecommerce-client",
    "ExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7,
    "ClockSkewSeconds": 0
  },
  "RateLimiting": {
    "GlobalLimit": 100,
    "GlobalWindowSeconds": 60,
    "AuthLimit": 5,
    "AuthWindowSeconds": 60,
    "PasswordResetLimit": 3,
    "PasswordResetWindowMinutes": 15,
    "RejectionStatusCode": 429
  },
  "PaymentWebhook": {
    "Secret": ""
  },
  "BusinessRules": {
    "FreeShippingThreshold": 100.00,
    "StandardShippingCost": 10.00,
    "TaxRate": 0.08
  },
  "Monitoring": {
    "EnableDetailedHealthChecks": true,
    "HealthCheckTimeoutMs": 5000,
    "MemoryThresholdMB": 1024,
    "EnableHealthCheckUI": false
  },
  "DataProtection": {
    "UseDatabaseStorage": true,
    "KeysDirectory": ""
  },
  "EmailProvider": "SendGrid",
  "SendGrid": {
    "ApiKey": "",
    "FromEmail": "noreply@ecommerce.com",
    "FromName": "E-Commerce Platform"
  },
  "Smtp": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "Username": "",
    "Password": "",
    "FromEmail": "",
    "FromName": "E-Commerce Platform",
    "EnableSsl": true
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/app-.txt",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/security-.txt",
          "rollingInterval": "Day",
          "restrictedToMinimumLevel": "Warning",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithCorrelationId"],
    "Properties": {
      "Application": "ECommerce.API"
    }
  },
  "Seq": {
    "ServerUrl": ""
  },
  "ApplicationInsights": {
    "InstrumentationKey": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
