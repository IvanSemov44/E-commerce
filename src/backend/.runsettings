<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <RunConfiguration>
    <!-- Disable parallel test execution to avoid flaky in-memory DB conflicts -->
    <MaxCpuCount>1</MaxCpuCount>
  </RunConfiguration>
  <MSTest>
    <!-- Additional MSTest configuration -->
    <Parallelize Workers="1" Scope="MethodLevel" />
  </MSTest>
</RunSettings>
