# Environment Variables Template
# Copy this file to .env.local and update values for your environment

# API Configuration
# Backend API base URL (include /api path)
# Development: http://localhost:5000/api
# Production: https://api.yourdomain.com/api
VITE_API_URL=http://localhost:5000/api

# Application Environment
# Options: development, production, staging
VITE_APP_ENV=development

# Feature Flags (optional, defaults are in config.ts)
# VITE_FEATURE_GUEST_CHECKOUT=true
# VITE_FEATURE_CART_SYNC=true
# VITE_FEATURE_WISHLIST=true
# VITE_FEATURE_REVIEWS=true
# VITE_FEATURE_PROMO_CODE=true

# Payment Integration (optional, if using Stripe/PayPal)
# VITE_STRIPE_PUBLIC_KEY=pk_test_...
# VITE_PAYPAL_CLIENT_ID=AB...

# Analytics (optional)
# VITE_GOOGLE_ANALYTICS_ID=G...
# VITE_AMPLITUDE_API_KEY=...

# Logging
# VITE_LOG_LEVEL=info
# Options: debug, info, warn, error
