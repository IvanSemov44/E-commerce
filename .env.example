# =============================================================================
# E-Commerce Platform Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# NEVER commit .env to source control!
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL Database Configuration (Docker Compose)
# -----------------------------------------------------------------------------
POSTGRES_USER=ecommerce
POSTGRES_DB=ECommerceDb
# REQUIRED: Set a strong password for the database
POSTGRES_PASSWORD=your-secure-password-here

# -----------------------------------------------------------------------------
# JWT Configuration
# -----------------------------------------------------------------------------
# REQUIRED: Must be at least 32 characters for security
# Generate a secure key: openssl rand -base64 32
JWT_SECRET_KEY=your-super-secret-key-min-32-characters
JWT_ISSUER=ecommerce-api
JWT_AUDIENCE=ecommerce-client
JWT_EXPIRE_MINUTES=60

# -----------------------------------------------------------------------------
# Email Configuration - SendGrid
# -----------------------------------------------------------------------------
# Optional: Required if using SendGrid as email provider
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=E-Commerce Platform

# -----------------------------------------------------------------------------
# Email Configuration - SMTP
# -----------------------------------------------------------------------------
# Optional: Required if using SMTP as email provider
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=E-Commerce Platform
SMTP_ENABLE_SSL=true

# -----------------------------------------------------------------------------
# Email Provider Selection
# -----------------------------------------------------------------------------
# Options: SendGrid, SMTP
EMAIL_PROVIDER=SendGrid

# -----------------------------------------------------------------------------
# Payment Webhook Configuration
# -----------------------------------------------------------------------------
# Optional: Secret for verifying payment webhook signatures
PAYMENT_WEBHOOK_SECRET=your-webhook-secret

# -----------------------------------------------------------------------------
# Application Environment
# -----------------------------------------------------------------------------
# Options: Development, Staging, Production
ASPNETCORE_ENVIRONMENT=Production

# -----------------------------------------------------------------------------
# CORS Configuration (Production)
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins for CORS
# Example: https://your-store.vercel.app,https://your-admin.vercel.app
ALLOWED_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com

# -----------------------------------------------------------------------------
# Frontend Configuration (Development)
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:5000/api/v1

# -----------------------------------------------------------------------------
# Frontend Configuration (Production - Vercel)
# -----------------------------------------------------------------------------
# Set these in Vercel dashboard for each project:
# Storefront: VITE_API_URL=https://your-api.onrender.com/api/v1
# Admin: VITE_API_URL=https://your-api.onrender.com/api/v1

# -----------------------------------------------------------------------------
# Business Rules Configuration
# -----------------------------------------------------------------------------
FREE_SHIPPING_THRESHOLD=100.00
STANDARD_SHIPPING_COST=10.00
TAX_RATE=0.08

# -----------------------------------------------------------------------------
# Monitoring Configuration
# -----------------------------------------------------------------------------
ENABLE_DETAILED_HEALTH_CHECKS=true
MEMORY_THRESHOLD_MB=1024

# -----------------------------------------------------------------------------
# Optional: External Services
# -----------------------------------------------------------------------------
# VITE_STRIPE_PUBLIC_KEY=pk_test_xxxxx
# VITE_GOOGLE_CLIENT_ID=xxxxx

# -----------------------------------------------------------------------------
# Optional: Logging & Monitoring (Production)
# -----------------------------------------------------------------------------
# SEQ_SERVER_URL=https://your-seq-server.com
# APPLICATION_INSIGHTS_INSTRUMENTATION_KEY=your-instrumentation-key
